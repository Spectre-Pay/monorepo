 /**
  * @title NativeCurrencyPaymentFallback - A contract that has a fallback to accept native currency payments.
  * @author Richard Meissner - @rmeissner
+ * @dev Patched by Spectre: when a guard is set, only the guard can send ETH directly.
  */
 abstract contract NativeCurrencyPaymentFallback {
     event SafeReceived(address indexed sender, uint256 value);
 
+    // keccak256("guard_manager.guard.address") — same slot as GuardManager
+    bytes32 private constant _GUARD_SLOT = 0x4a204f620c8c5ccdca3fd54d003badd85ba500436a431f0cbda4f558c93c34c8;
+
     /**
      * @notice Receive function accepts native currency transactions.
-     * @dev Emits an event with sender and received value.
+     * @dev If a guard is set, only the guard address may send ETH directly.
+     *      This forces all other inbound ETH through the guard's fallback (with TEE attestation).
      */
     receive() external payable {
+        address guard;
+        bytes32 slot = _GUARD_SLOT;
+        assembly {
+            guard := sload(slot)
+        }
+        if (guard != address(0)) {
+            require(msg.sender == guard, "GS900: only guard can forward ETH");
+        }
         emit SafeReceived(msg.sender, msg.value);
     }
 }
